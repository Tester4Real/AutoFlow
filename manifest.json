{
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "js": [
        "src/content/page-fetch-interceptor.js"
      ],
      "matches": [
        "https://labs.google/fx/*/tools/flow*",
        "https://labs.google/fx/tools/flow*"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "js": [
        "src/content/flow-page-bridge.js"
      ],
      "matches": [
        "https://labs.google/fx/*/tools/flow*",
        "https://labs.google/fx/tools/flow*"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "description": "Google Flow personal automation build with direct connection responder fix.",
  "host_permissions": [
    "https://labs.google/*"
  ],
  "icons": {
    "128": "assets/icons/icon128.png",
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png"
  },
  "key": "",
  "manifest_version": 3,
  "name": "TurboFlow - Auto Veo & Nano Banana Pro on Google Flow",
  "permissions": [
    "sidePanel",
    "scripting",
    "storage",
    "tabs",
    "unlimitedStorage",
    "downloads",
    "activeTab"
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "version": "2.2.21"
}
